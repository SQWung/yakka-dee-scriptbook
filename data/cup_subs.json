[
  {
    "text": "Dee? Where are you?",
    "from": "0:02",
    "to": "0:04",
    "cn": "迪伊？你在哪里？"
  },
  {
    "text": "I've seen her. Over there.",
    "from": "0:04",
    "to": "0:06",
    "cn": "我见过她。在那边。"
