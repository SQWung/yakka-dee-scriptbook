[
  {
    "text": "- Dee? Where are you?\n- I've seen her!",
    "from": "0:02",
    "to": "0:04",
    "cn": "- 迪伊？你在哪里？\n- 我见过她！"
  },
  {
    "text": "Over there!",
    "from": "0:04",
    "to": "0:06",
    "cn": "在那边！"
  },
  {
    "text": "Dee!",
    "from": "0:06",
    "to": "0:07",
    "cn": "迪伊！"
  },
  {
    "text": "# Yakka Dee, Yakka Dee, Yakka Dee, Yakka Dee",
    "from": "0:08",
