  },
  {
    "text": "- # Yakka Yak\n- # Yakka Dee",
    "from": "0:24",
    "to": "0:26",
    "cn": "- # 雅卡牦牛\n- # 雅卡迪伊"
  },
  {
    "text": "- # I know you can\n- # Yakka Dee",
    "from": "0:26",
    "to": "0:28",
    "cn": "- # 我知道你可以\n- # 雅卡迪伊"
  },
  {
    "text": "- # You'll get filled up\n- # Yakka Dee",
    "from": "0:28",
    "to": "0:30",
    "cn": "- # 你会被填满\n- # 雅卡迪伊"
  },
  {
    "text": "# With whizz, pop, bang",
