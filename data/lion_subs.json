  },
  {
    "text": "- # I know you can\n- # Yakka Dee!",
    "from": "0:26",
    "to": "0:28",
    "cn": "- # 我知道你可以\n- # 雅卡迪伊！"
  },
  {
    "text": "- # You'll get filled up\n- # Yakka Dee!",
