[
  {
    "text": "- Dee? Where are you?\n- I've seen her. Over there.",
    "from": "0:02",
    "to": "0:06",
    "cn": "- 迪伊？你在哪里？\n- 我见过她。在那边。"
  },
  {
    "text": "Dee?",
    "from": "0:06",
    "to": "0:08",
    "cn": "迪伊？"
  },
  {
    "text": "# Yakka Dee! Yakka Dee!",
    "from": "0:08",
    "to": "0:11",
    "cn": "【歌曲】雅卡迪！雅卡迪！"
  },
  {
    "text": "# Yakka Dee! Yakka Dee!",
    "from": "0:11",
    "to": "0:12",
    "cn": "【歌曲】雅卡迪！雅卡迪！"
  },
  {
    "text": "# My name is Dee, I like to talk",
    "from": "0:12",
    "to": "0:14",
    "cn": "【歌曲】我叫迪伊，我喜欢说话"
  },
  {
    "text": "- # They call me Yakka Dee!\n- # Dee",
    "from": "0:14",
    "to": "0:16",
    "cn": "- # 他们叫我 雅卡 迪伊！\n-#迪伊"
  },
  {
    "text": "# Talking makes us happy",
    "from": "0:16",
    "to": "0:18",
    "cn": "【歌曲】说话让我们快乐"
  },
  {
    "text": "- # Will you Yakka Yak with me?\n- # Me",
    "from": "0:18",
    "to": "0:21",
    "cn": "- # 你愿意和我一起 雅卡 Yak 吗？\n- ＃ 我"
  },
  {
    "text": "# Bus, mouse, apple, house",
